				<string>on run argv

tell application "System Events"
	tell process "Books"
		-- Give Books a moment to settle its window state
		delay 0.5

		repeat with w in windows
			try
				set wName to name of w as text
				set roleDesc to role description of w

				-- Only close the main library window
				if wName is "All" or roleDesc is "main window" then
					if (exists button 1 of w) then
						click button 1 of w
						do shell script "echo Closed library window (" &amp; quoted form of wName &amp; ") 1&gt;&amp;2"
					end if
				else
					do shell script "echo Skipped window: " &amp; quoted form of wName &amp; " [" &amp; roleDesc &amp; "] 1&gt;&amp;2"
				end if

			on error errMsg
				do shell script "echo Error: " &amp; quoted form of errMsg &amp; " 1&gt;&amp;2"
			end try
		end repeat
	end tell
end tell


end run</string>
