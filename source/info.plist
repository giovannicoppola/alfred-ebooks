				<string>query=$1

if [[ "$1" == yomu-open\|* ]]; then
  payload=${1#yomu-open|}
  meta_id=${payload%%|*}
  rest=${payload#*|}
  doc_id=${rest%%|*}
  file_id=${rest#*|}
  base_url="https://links.yomu-reader.com/intent-document?id="
  suffix="&amp;source=intent-document-entity&amp;medium=intents"

  open -a "/Applications/Yomu.app"
  sleep 1

  if [ -n "$meta_id" ]; then
    open -a "/Applications/Yomu.app" "${base_url}${meta_id}${suffix}"
    sleep 0.2
  fi

  if [ -n "$doc_id" ]; then
    open -a "/Applications/Yomu.app" "${base_url}${doc_id}${suffix}"
    sleep 0.2
  fi

  if [ -n "$file_id" ] &amp;&amp; [ "$file_id" != "$doc_id" ] &amp;&amp; [ "$file_id" != "$meta_id" ]; then
    open -a "/Applications/Yomu.app" "${base_url}${file_id}${suffix}"
  fi
elif [[ "$1" == calibre-open\|* ]]; then
  payload=${1#calibre-open|}
  book_path=${payload%%|*}
  open_location=""
  if [ "$payload" != "$book_path" ]; then
    open_location=${payload#*|}
  fi

  if [ -n "$open_location" ]; then
    case "$open_location" in
      toc:*|toc-href:*|toc-href-contains:*|ref:*|search:*|regex:*)
        ;;
      *)
        open_location="toc-href-contains:$open_location"
        ;;
    esac
  fi

  viewer_bin=""
  if command -v ebook-viewer &gt;/dev/null 2&gt;&amp;1; then
    viewer_bin=$(command -v ebook-viewer)
  elif [ -x "/Applications/calibre.app/Contents/MacOS/ebook-viewer" ]; then
    viewer_bin="/Applications/calibre.app/Contents/MacOS/ebook-viewer"
  fi

  if [ -n "$viewer_bin" ]; then
    if [ -n "$open_location" ]; then
      (
        nohup "$viewer_bin" --open-at="$open_location" "$book_path" &gt;/dev/null 2&gt;&amp;1 ||
        nohup "$viewer_bin" "$book_path" &gt;/dev/null 2&gt;&amp;1
      ) &amp;
    else
      nohup "$viewer_bin" "$book_path" &gt;/dev/null 2&gt;&amp;1 &amp;
    fi
  else
    # Last resort: open with system default app to avoid triggering Calibre import dialogs.
    open "$book_path"
  fi
elif [[ "$1" == kindle-lassen-open\|* ]]; then
  bash "${PWD}/kindle-lassen-open.sh" "$1"
else
  open "$1"
fi</string>
